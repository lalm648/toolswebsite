NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# Optional lead capture provider settings
NEXT_PUBLIC_NEWSLETTER_PROVIDER=
NEXT_PUBLIC_NEWSLETTER_URL=
NEXT_PUBLIC_NEWSLETTER_METHOD=post
NEXT_PUBLIC_NEWSLETTER_EMAIL_FIELD=email
NEXT_PUBLIC_NEWSLETTER_SOURCE_FIELD=source
NEXT_PUBLIC_NEWSLETTER_TARGET=_blank
NEXT_PUBLIC_NEWSLETTER_HIDDEN_FIELDS=

NEXT_PUBLIC_WAITLIST_PROVIDER=
NEXT_PUBLIC_WAITLIST_URL=
NEXT_PUBLIC_WAITLIST_METHOD=post
NEXT_PUBLIC_WAITLIST_EMAIL_FIELD=email
NEXT_PUBLIC_WAITLIST_SOURCE_FIELD=source
NEXT_PUBLIC_WAITLIST_TARGET=_blank
NEXT_PUBLIC_WAITLIST_HIDDEN_FIELDS=

# Optional visibility flags
NEXT_PUBLIC_SHOW_AD_SLOTS=false
NEXT_PUBLIC_SHOW_SPONSORED_BLOCKS=false
NEXT_PUBLIC_SHOW_NEWSLETTER_SIGNUP=true
NEXT_PUBLIC_SHOW_WAITLIST_BLOCK=true
